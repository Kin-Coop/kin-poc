<?xml version="1.0"?>
<extension key="firewall" type="module">
  <file>firewall</file>
  <name>Firewall</name>
  <description>IP based Firewall to prevent certain types of attack</description>
  <license>AGPL-3.0</license>
  <authors>
    <author>
      <name>MJW</name>
      <email>info@mjwconsult.co.uk</email>
      <role>Maintainer</role>
    </author>
  </authors>
  <urls>
    <url desc="Main Extension Page">https://lab.civicrm.org/extensions/firewall</url>
    <url desc="Release Notes">https://docs.civicrm.org/firewall/en/latest/releasenotes/</url>
    <url desc="Documentation">https://docs.civicrm.org/firewall</url>
    <url desc="Support">https://mjw.pt/support/firewall</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-06-22</releaseDate>
  <version>1.7.1</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.14</ver>
  </compatibility>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
    <psr0 prefix="CRM_" path="."/>
  </classloader>
  <civix>
    <namespace>CRM/Firewall</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>entity-types-php@2.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
    <mixin>setting-admin@1.0.1</mixin>
  </mixins>
  <upgrader>CiviMix\Schema\Firewall\AutomaticUpgrader</upgrader>
</extension>
