<?xml version="1.0"?>
<extension key="uk.co.vedaconsulting.gdpr" type="module">
  <file>gdpr</file>
  <name>General Data Protection Regulation</name>
  <description>Extension to support General Data Protection Regulation</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Veda NFP Consulting Ltd</author>
    <email>support@vedaconsulting.co.uk</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://lab.civicrm.org/extensions/gdpr</url>
    <url desc="Documentation">https://docs.civicrm.org/gdpr/en/latest/</url>
    <url desc="Support">https://vedaconsulting.co.uk</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-06-11</releaseDate>
  <version>3.8.3</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.12</ver>
  </compatibility>
  <php_compatibility>
    <ver>8.1</ver>
    <ver>8.2</ver>
    <ver>8.3</ver>
    <ver>8.4</ver>
  </php_compatibility>
  <smarty_compatibility>
    <ver>5</ver>
  </smarty_compatibility>
  <civix>
    <namespace>CRM/Gdpr</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <upgrader>CRM_Gdpr_Upgrader</upgrader>
</extension>
